class Plugin extends AppPlugin {

    onLoad() {
        this.ui.addCommandPaletteCommand({
            label: "Export to PDF",
            icon: "file-description",
            onSelected: () => this.exportToPDF()
        });
    }

    async exportToPDF() {
        const panel = this.ui.getActivePanel();
        const record = panel?.getActiveRecord();

        if (!record) {
            this.ui.addToaster({
                title: "Export to PDF",
                message: "No document is currently open.",
                dismissible: true,
                autoDestroyTime: 3000,
            });
            return;
        }

        const title = record.getName();
        const lineItems = await record.getLineItems();

        // Only top-level items — we'll recurse for children
        const topLevel = lineItems.filter(i => i.parent_guid === record.guid);

        const container = document.createElement('div');
        container.id = 'thymer-pdf-export';
        container.style.cssText = `
            background: white;
            color: black;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            font-size: 12pt;
            line-height: 1.6;
            padding: 0.75in;
            max-width: 8.5in;
        `;

        const h1 = document.createElement('h1');
        h1.textContent = title;
        h1.style.cssText = 'margin: 0 0 1em 0; font-size: 22pt; border-bottom: 1px solid #ddd; padding-bottom: 0.3em;';
        container.appendChild(h1);

        const objectUrls = [];
        await this.renderItems(topLevel, container, lineItems, 0, objectUrls);

        document.body.appendChild(container);

        const style = document.createElement('style');
        style.id = 'thymer-pdf-print-style';
        style.textContent = `
            @media print {
                body > *:not(#thymer-pdf-export) { display: none !important; }
                #thymer-pdf-export { display: block !important; position: static; width: auto; }
                @page { margin: 0.5in; }
            }
        `;
        document.head.appendChild(style);

        this.ui.addToaster({
            title: "Export to PDF",
            message: "Choose 'Save as PDF' in the print dialog.",
            dismissible: false,
            autoDestroyTime: 3000,
        });

        setTimeout(() => {
            window.print();
            setTimeout(() => {
                objectUrls.forEach((u) => URL.revokeObjectURL(u));
                container.remove();
                style.remove();
            }, 1000);
        }, 300);
    }

    appendBlankParagraph(container, depth) {
        const p = document.createElement('p');
        p.style.cssText = 'margin: 0.3em 0 0.3em ' + (depth * 20) + 'px;';
        p.appendChild(document.createElement('br'));
        container.appendChild(p);
    }

    async renderItems(items, container, allItems, depth, objectUrls) {
        let currentList = null;
        let currentListType = null;

        for (const item of items) {
            const children = allItems.filter(i => i.parent_guid === item.guid);
            const type = item.type;

            // Close any open list if this item isn't a list type
            if (type !== 'ulist' && type !== 'olist' && type !== 'task') {
                currentList = null;
                currentListType = null;
            }

            if (type === 'br' || type === 'empty') {
                currentList = null;
                currentListType = null;
                this.appendBlankParagraph(container, depth);
                if (children.length) await this.renderItems(children, container, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'heading') {
                currentList = null;
                currentListType = null;
                const size = item.getHeadingSize?.() ?? 1;
                const level = Math.min(size + 1, 6); // h1 is the title, so start at h2
                const el = document.createElement(`h${level}`);
                el.style.cssText = 'margin: 0.8em 0 0.3em 0;';
                el.appendChild(this.segmentsToSpan(item.segments));
                container.appendChild(el);
                if (children.length) await this.renderItems(children, container, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'task') {
                if (currentListType !== 'task') {
                    currentList = document.createElement('ul');
                    currentList.style.cssText = 'list-style: none; padding-left: ' + (depth * 20 + 20) + 'px; margin: 0.3em 0;';
                    container.appendChild(currentList);
                    currentListType = 'task';
                }
                const li = document.createElement('li');
                const isDone = item.isTaskCompleted?.() === true;
                const checkbox = isDone ? '☑' : '☐';
                li.style.cssText = `margin: 0.15em 0; ${isDone ? 'color: #999; text-decoration: line-through;' : ''}`;
                const checkSpan = document.createElement('span');
                checkSpan.textContent = checkbox + ' ';
                checkSpan.style.marginRight = '4px';
                li.appendChild(checkSpan);
                li.appendChild(this.segmentsToSpan(item.segments));
                currentList.appendChild(li);
                if (children.length) await this.renderItems(children, li, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'ulist') {
                if (currentListType !== 'ulist') {
                    currentList = document.createElement('ul');
                    currentList.style.cssText = 'padding-left: ' + (depth * 20 + 20) + 'px; margin: 0.3em 0;';
                    container.appendChild(currentList);
                    currentListType = 'ulist';
                }
                const li = document.createElement('li');
                li.style.margin = '0.15em 0';
                li.appendChild(this.segmentsToSpan(item.segments));
                currentList.appendChild(li);
                if (children.length) await this.renderItems(children, li, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'olist') {
                if (currentListType !== 'olist') {
                    currentList = document.createElement('ol');
                    currentList.style.cssText = 'padding-left: ' + (depth * 20 + 20) + 'px; margin: 0.3em 0;';
                    container.appendChild(currentList);
                    currentListType = 'olist';
                }
                const li = document.createElement('li');
                li.style.margin = '0.15em 0';
                li.appendChild(this.segmentsToSpan(item.segments));
                currentList.appendChild(li);
                if (children.length) await this.renderItems(children, li, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'quote' || type === 'block') {
                currentList = null;
                currentListType = null;
                const blockquote = document.createElement('blockquote');
                blockquote.style.cssText = 'border-left: 3px solid #ccc; margin: 0.5em 0 0.5em ' + (depth * 20) + 'px; padding: 0.3em 0.8em; color: #555;';
                blockquote.appendChild(this.segmentsToSpan(item.segments));
                container.appendChild(blockquote);
                if (children.length) await this.renderItems(children, blockquote, allItems, depth + 1, objectUrls);
                continue;
            }

            if (type === 'image') {
                currentList = null;
                currentListType = null;
                const wrap = document.createElement('div');
                wrap.style.cssText = 'margin: 0.5em 0 0.5em ' + (depth * 20) + 'px;';
                let shown = false;
                try {
                    const blob = await item.getBlob();
                    if (blob) {
                        const buf = await blob.download();
                        if (buf && buf.byteLength > 0) {
                            const mime = blob.contentType || 'application/octet-stream';
                            const url = URL.createObjectURL(new Blob([buf], { type: mime }));
                            objectUrls.push(url);
                            const img = document.createElement('img');
                            img.src = url;
                            img.alt = blob.fileName || '';
                            img.style.cssText = 'max-width: 100%; height: auto; display: block;';
                            const applyImageScale = () => {
                                const w = img.naturalWidth;
                                if (w > 0) {
                                    img.style.width = `${Math.round(w * 0.65)}px`;
                                }
                            };
                            img.onload = applyImageScale;
                            if (img.complete) applyImageScale();
                            wrap.appendChild(img);
                            shown = true;
                        }
                    }
                } catch (_) { /* blob unavailable */ }
                if (!shown) {
                    const fallback = document.createElement('span');
                    fallback.style.cssText = 'color: #888; font-style: italic;';
                    fallback.textContent = '[Image]';
                    wrap.appendChild(fallback);
                }
                container.appendChild(wrap);
                if (children.length) await this.renderItems(children, container, allItems, depth + 1, objectUrls);
                continue;
            }

            // Default: text / paragraph
            currentList = null;
            currentListType = null;
            if (!item.segments?.length) {
                if (type === 'text') {
                    this.appendBlankParagraph(container, depth);
                    if (children.length) await this.renderItems(children, container, allItems, depth + 1, objectUrls);
                }
                continue;
            }
            const p = document.createElement('p');
            p.style.cssText = 'margin: 0.3em 0 0.3em ' + (depth * 20) + 'px;';
            p.appendChild(this.segmentsToSpan(item.segments));
            container.appendChild(p);
            if (children.length) await this.renderItems(children, container, allItems, depth + 1, objectUrls);
        }
    }

    segmentsToSpan(segments) {
        const frag = document.createDocumentFragment();
        if (!segments?.length) return frag;

        for (const seg of segments) {
            const text = typeof seg.text === 'string' ? seg.text : '';

            if (seg.type === 'bold') {
                const el = document.createElement('strong');
                el.textContent = text;
                frag.appendChild(el);
            } else if (seg.type === 'italic') {
                const el = document.createElement('em');
                el.textContent = text;
                frag.appendChild(el);
            } else if (seg.type === 'code') {
                const el = document.createElement('code');
                el.textContent = text;
                el.style.cssText = 'background: #f0f0f0; padding: 1px 4px; border-radius: 3px; font-size: 0.9em;';
                frag.appendChild(el);
            } else if (seg.type === 'link') {
                const el = document.createElement('a');
                el.href = text;
                el.textContent = text;
                el.style.color = '#333';
                frag.appendChild(el);
            } else if (seg.type === 'linkobj') {
                const el = document.createElement('a');
                el.href = seg.text?.link ?? '#';
                el.textContent = seg.text?.title ?? seg.text?.link ?? '';
                el.style.color = '#333';
                frag.appendChild(el);
            } else if (seg.type === 'datetime') {
                const el = document.createElement('span');
                el.textContent = text;
                el.style.cssText = 'background: #f0f0f0; padding: 1px 4px; border-radius: 3px; font-size: 0.9em;';
                frag.appendChild(el);
            } else if (seg.type === 'hashtag') {
                const el = document.createElement('span');
                el.textContent = text;
                el.style.color = '#555';
                frag.appendChild(el);
            } else {
                // text, mention, ref, icon — just render as plain text
                const el = document.createTextNode(text);
                frag.appendChild(el);
            }
        }

        return frag;
    }
}